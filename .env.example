# ============================================================
#  PawPredict AI — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to git.
# ============================================================

# Your Anthropic API key — stays server-side only
# Get it at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Rate limiting: max requests per IP per window (default: 10 per minute)
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# Your production domain (used for CORS validation)
# e.g. https://pawpredict.ai  — no trailing slash
NEXT_PUBLIC_APP_URL=http://localhost:3000
